# ─────────────────────────────────────────────────
# NotionCares — Telegram MCP  /  .env
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────

# 1. Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# 2. Your personal Telegram chat ID.
#    Run: python get_chat_id.py  after sending your bot any message.
TELEGRAM_CHAT_ID=987654321

# 3. The public HTTPS base URL of THIS server.
#    For local dev: use ngrok → ngrok http 8001 → copy the https URL
#    For production: your Cloud Run / Railway URL
#    NO trailing slash.
PUBLIC_BASE_URL=https://xxxx-xx-xx-xxx-xx.ngrok-free.app

# 4. Port for the MCP server (Notion connects here)
MCP_PORT=8001

# 5. Port for the Telegram webhook receiver
WEBHOOK_PORT=8002
